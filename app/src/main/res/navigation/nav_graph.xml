<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/nav_login">

    <fragment
        android:id="@+id/nav_home"
        android:name="com.example.diary_app.ui.pages.homepage.HomeFragment"
        android:label="Home"/>

    <fragment
            android:id="@+id/nav_chatroom"
            android:name="com.example.diary_app.ui.pages.chat.ChatDashboardFragment"
            android:label="ChatRoom"/>

    <fragment
        android:id="@+id/nav_chat"
        android:name="com.example.diary_app.ui.pages.chat.ChatFragment"
        android:label="Chat"/>

    <fragment
        android:id="@+id/nav_chatAI"
        android:name="com.example.diary_app.ui.pages.chat.ChatAIFragment"
        android:label="ChatAI"/>

    <fragment
        android:id="@+id/nav_search"
        android:name="com.example.diary_app.ui.pages.search.SearchFragment"
        android:label="Search"/>

    <fragment
        android:id="@+id/nav_pet"
        android:name="com.example.diary_app.ui.pages.pet.PetFragment"
        android:label="Pet"/>

    <fragment
        android:id="@+id/nav_dashboard"
        android:name="com.example.diary_app.ui.pages.statistics.StaticticsFragment"
        android:label="Dashboard"/>

    <fragment
        android:id="@+id/nav_login"
        android:name="com.example.diary_app.ui.pages.login.LoginFragment"
        android:label="Login">

        <action
            android:id="@+id/action_nav_login_to_nav_signin"
            app:destination="@id/nav_signin" />

        <action
            android:id="@+id/action_nav_login_to_nav_home"
            app:destination="@id/nav_home"
            app:popUpTo="@id/nav_login"
            app:popUpToInclusive="true" />

    </fragment>

    <fragment
        android:id="@+id/nav_signin"
        android:name="com.example.diary_app.ui.pages.signup.SignupFragment"
        android:label="Signup"/>

    <fragment
        android:id="@+id/nav_profile"
        android:name="com.example.diary_app.ui.pages.profile.ProfileFragment"
        android:label="Profile">

        <action
            android:id="@+id/action_nav_profile_to_nav_edit_profile"
            app:destination="@id/nav_edit_profile" />

    </fragment>

    <fragment
        android:id="@+id/nav_edit_profile"
        android:name="com.example.diary_app.ui.pages.profile.EditProfileFragment"
        android:label="Edit Profile" />

    <fragment
        android:id="@+id/nav_notification"
        android:name="com.example.diary_app.ui.pages.notification.NotificationFragment"
        android:label="Notification">

        <action
            android:id="@+id/action_nav_notification_to_nav_profile"
            app:destination="@id/nav_profile" />
    </fragment>

    <fragment
        android:id="@+id/nav_addfriend"
        android:name="com.example.diary_app.ui.pages.friend.AddFriendFragment"
        android:label="Add Friend"/>
    <fragment
        android:id="@+id/nav_admin"
        android:name="com.example.diary_app.fragment_adminreview"
        android:label="admin"/>



</navigation>
