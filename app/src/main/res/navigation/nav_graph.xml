<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/nav_login">

    <fragment
        android:id="@+id/nav_home"
        android:name="com.example.diary_app.ui.pages.homepage.HomeFragment"
        android:label="Home"/>


    <fragment
        android:id="@+id/nav_chat"
        android:name="com.example.diary_app.ui.pages.chat.ChatFragment"
        android:label="Chat"/>

    <fragment
        android:id="@+id/nav_chatAI"
        android:name="com.example.diary_app.ui.pages.chat.ChatAIFragment"
        android:label="ChatAI"/>

    <fragment
        android:id="@+id/nav_dashboard"
        android:name="com.example.diary_app.ui.pages.statistics.StaticticsFragment"
        android:label="Dashboard"/>

    <fragment
        android:id="@+id/nav_profile"
        android:name="com.example.diary_app.ui.pages.profile.ProfileFragment"
        android:label="Profile"/>

    <fragment
        android:id="@+id/nav_login"
        android:name="com.example.diary_app.ui.pages.login.LoginFragment"
        android:label="Login">

        <action
            android:id="@+id/action_nav_login_to_nav_signin"
            app:destination="@id/nav_signin" />

        <action
            android:id="@+id/action_nav_login_to_nav_home"
            app:destination="@id/nav_home"
            app:popUpTo="@id/nav_login"
            app:popUpToInclusive="true" />

    </fragment>

    <fragment
        android:id="@+id/nav_signin"
        android:name="com.example.diary_app.ui.pages.signup.SignupFragment"
        android:label="Signup"/>

    <fragment
        android:id="@+id/nav_editprofile"
        android:name="com.example.diary_app.ui.pages.profile.EditProfileFragment"
        android:label="EditProfile"/>

</navigation>