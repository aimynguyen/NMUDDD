<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_lineargradient"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tùy chỉnh Video"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"
        android:textColor="@color/blue_secondary" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Chọn nhạc nền:"
        android:layout_marginBottom="8dp" />

    <Spinner
        android:id="@+id/spinnerMusic"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Thời lượng mỗi ảnh (giây):"
        android:layout_marginBottom="8dp" />

    <SeekBar
        android:id="@+id/seekBarDuration"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="10"
        android:progress="3"
        android:min="1" />

    <TextView
        android:id="@+id/tvDurationValue"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="3 giây"
        android:textAlignment="center"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="16dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end">

        <Button
            android:id="@+id/btnCancel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/blue_secondary"
            android:text="Hủy"
            style="?android:attr/buttonBarButtonStyle" />

        <Button
            android:id="@+id/btnStartExport"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tạo Video"
            android:textColor="@color/white"
            android:backgroundTint="@color/blue_secondary" />
    </LinearLayout>

</LinearLayout>
