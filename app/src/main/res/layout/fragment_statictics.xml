<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/bg_lineargradient">

    <!-- ScrollView chứa nội dung, nằm giữa Header và Navbar -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        tools:ignore="MissingConstraints"> <!-- Kết thúc ScrollView tại Navbar -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp">

<!--            top emotion-->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/white"
                app:strokeWidth="0dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="8dp"
                android:layout_marginLeft="16dp"
                android:layout_marginRight="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="5dp"
                    android:orientation="vertical">

                    <TextView
                        android:text="Top emotion"
                        android:layout_height="wrap_content"
                        android:layout_width="match_parent"
                        android:layout_marginTop="5dp"
                        android:textSize="16dp"
                        android:textStyle="bold"
                        android:layout_marginLeft="30dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="5dp"
                        android:layout_marginBottom="12dp"
                        android:weightSum="3"> <LinearLayout
                        android:id="@+id/layout_top1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:visibility="invisible"> <View
                        android:id="@+id/img_top1"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:background="@drawable/bg_circle_happy"
                        android:layout_gravity="center_vertical"/>
                        <TextView
                            android:id="@+id/txt_top1"
                            android:text="Top 1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="5dp"
                            android:textSize="12dp"
                            android:textStyle="normal"
                            android:layout_gravity="center_vertical"/>
                    </LinearLayout>

                        <LinearLayout
                            android:id="@+id/layout_top2"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="horizontal"
                            android:gravity="center"
                            android:visibility="invisible">
                            <View
                                android:id="@+id/img_top2"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:background="@drawable/bg_circle_angry"
                                android:layout_gravity="center_vertical"/>
                            <TextView
                                android:id="@+id/txt_top2"
                                android:text="Top 2"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginLeft="5dp"
                                android:textSize="12dp"
                                android:textStyle="normal"
                                android:layout_gravity="center_vertical"/>
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/layout_top3"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="horizontal"
                            android:gravity="center"
                            android:visibility="invisible">
                            <View
                                android:id="@+id/img_top3"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:background="@drawable/bg_circle_neutral"
                                android:layout_gravity="center_vertical"/>
                            <TextView
                                android:id="@+id/txt_top3"
                                android:text="Top 3"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginLeft="5dp"
                                android:textSize="12dp"
                                android:textStyle="normal"
                                android:layout_gravity="center_vertical"/>
                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

<!--            chart-->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="166dp"
                    android:layout_margin="16dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="8dp"
                    app:cardBackgroundColor="@android:color/white"
                    android:layout_weight="1">

                    <com.anychart.AnyChartView
                        android:id="@+id/pieChart"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent" />
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="166dp"
                    android:layout_margin="16dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="8dp"
                    app:cardBackgroundColor="@android:color/white"
                    android:layout_weight="1">

                    <com.anychart.AnyChartView
                        android:id="@+id/barChart"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"/>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

<!--            mô tả cảm xúc-->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_white_transparent"
                android:layout_marginLeft="16dp"
                android:layout_marginRight="16dp"
                android:paddingTop="5dp"
                android:paddingBottom="5dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <View
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:background="@drawable/bg_circle_calm"
                        android:layout_gravity="center_vertical"/>
                    <TextView
                        android:text="Calm"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="5dp"
                        android:textSize="12sp"
                        android:textStyle="normal"
                        android:layout_gravity="center_vertical"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <View
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:background="@drawable/bg_circle_neutral"
                        android:layout_gravity="center_vertical"/>
                    <TextView
                        android:text="Neutral"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="5dp"
                        android:textSize="12sp"
                        android:textStyle="normal"
                        android:layout_gravity="center_vertical"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <View
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:background="@drawable/bg_circle_sad"
                        android:layout_gravity="center_vertical"/>
                    <TextView
                        android:text="Sad"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="5dp"
                        android:textSize="12sp"
                        android:textStyle="normal"
                        android:layout_gravity="center_vertical"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <View
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:background="@drawable/bg_circle_angry"
                        android:layout_gravity="center_vertical"/>
                    <TextView
                        android:text="Angry"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="5dp"
                        android:textSize="12sp"
                        android:textStyle="normal"
                        android:layout_gravity="center_vertical"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <View
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:background="@drawable/bg_circle_happy"
                        android:layout_gravity="center_vertical"/>
                    <TextView
                        android:text="Happy"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="5dp"
                        android:textSize="12sp"
                        android:textStyle="normal"
                        android:layout_gravity="center_vertical"/>
                </LinearLayout>

            </LinearLayout>

            <!-- Lịch: Đã gộp vào bên trong LinearLayout duy nhất của ScrollView -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="16dp">
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:backgroundTint="@color/white"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="8dp"
                    app:strokeWidth="0dp"
                    android:layout_marginLeft="16dp"
                    android:layout_marginRight="16dp"
                    android:layout_marginBottom="16dp"
                    android:layout_marginTop="8dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="55dp"
                            android:orientation="horizontal">
                            <TextView
                                android:id="@+id/month"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="May"
                                android:textSize="16sp"
                                android:layout_marginLeft="32dp"
                                android:layout_gravity="center_vertical"/>
                            <TextView
                                android:id="@+id/year"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="2026"
                                android:textSize="16sp"
                                android:layout_marginLeft="4dp"
                                android:layout_gravity="center_vertical"/>
                            <ImageButton
                                android:id="@+id/btnDropDown"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:src="@drawable/ic_dropdown"
                                android:layout_marginLeft="8dp"
                                android:background="@null"
                                android:layout_gravity="center_vertical"/>
                            <View
                                android:layout_width="0dp"
                                android:layout_height="0dp"
                                android:layout_weight="1"/>
                            <ImageButton
                                android:id="@+id/btnPre"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:src="@drawable/ic_calendar_pre"
                                android:layout_marginLeft="8dp"
                                android:background="@null"
                                android:layout_gravity="center_vertical"/>
                            <ImageButton
                                android:id="@+id/btnNext"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:src="@drawable/ic_calendar_next"
                                android:background="@null"
                                android:paddingRight="24dp"
                                android:layout_gravity="center_vertical"/>
                        </LinearLayout>
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:layout_marginLeft="16dp"
                            android:layout_marginRight="16dp">

                        </LinearLayout>
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="5dp"
                            android:layout_marginLeft="32dp"
                            android:layout_marginRight="32dp"
                            android:background="@drawable/dash_line"/>
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginLeft="16dp"
                            android:layout_marginRight="16dp"
                            android:paddingTop="8dp"
                            android:layout_marginTop="8dp"
                            android:background="@color/blue_primary"
                            android:paddingBottom="8dp">

                            <TextView
                                android:text="Mo"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:textStyle="bold"/>

                            <TextView
                                android:text="Tu"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:textStyle="bold"/>

                            <TextView
                                android:text="We"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:textStyle="bold"/>

                            <TextView
                                android:text="Th"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:textStyle="bold"/>

                            <TextView
                                android:text="Fr"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:textStyle="bold"/>

                            <TextView
                                android:text="Sa"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:textStyle="bold"/>

                            <TextView
                                android:text="Su"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:textStyle="bold"/>
                        </LinearLayout>

                        <GridLayout
                            android:id="@+id/gridCalendar"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:columnCount="7"
                            android:rowCount="6"
                            android:paddingTop="4dp"
                            android:paddingBottom="12dp"
                            android:paddingRight="12dp"
                            android:paddingLeft="12dp"/>
                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

<!--            chuyển đến map-->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp"
                android:layout_margin="16dp"
                app:strokeWidth="0dp"
                android:backgroundTint="@color/white">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_location_pin"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">

                        <TextView
                            android:text="1. University of Information Technology"
                            android:textSize="14sp"
                            android:textColor="@android:color/black"
                            android:layout_height="wrap_content"
                            android:maxWidth="200sp"
                            android:layout_width="wrap_content"
                            android:singleLine="true"/>

                        <TextView
                            android:text="2. Thao Cam Vien"
                            android:textSize="14sp"
                            android:layout_marginTop="8dp"
                            android:textColor="@android:color/black"
                            android:maxWidth="200sp"
                            android:singleLine="true"
                            android:layout_height="wrap_content"
                            android:layout_width="wrap_content"/>
                    </LinearLayout>

                    <!-- Icon bản đồ + nút See more -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">



                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnSeeMore"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="See more →"
                            android:textSize="14sp"
                            android:textColor="@color/blue_secondary"
                            android:backgroundTint="@color/blue_primary"
                            app:iconTint="@null"
                            app:icon="@drawable/ic_map"
                            app:iconPadding="4dp"
                            app:iconGravity="textStart"/>

                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>



</androidx.constraintlayout.widget.ConstraintLayout>
