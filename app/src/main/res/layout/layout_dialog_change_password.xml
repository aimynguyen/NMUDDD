<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/bg_gradient_01">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Đổi mật khẩu"
        android:textColor="@color/text_primary"
        android:textSize="22sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="16dp"/>

    <!-- Current Password -->
    <EditText
        android:id="@+id/edtCurrentPassword"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:hint="Mật khẩu hiện tại"
        android:inputType="textPassword"
        android:background="@drawable/bg_input_rounded"
        android:elevation="4dp"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:layout_marginBottom="16dp"
        android:textColor="@color/text_primary"
        android:textColorHint="#9AA0A6"/>

    <!-- New Password -->
    <EditText
        android:id="@+id/edtNewPassword"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:hint="Mật khẩu mới"
        android:inputType="textPassword"
        android:background="@drawable/bg_input_rounded"
        android:elevation="4dp"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:layout_marginBottom="16dp"
        android:textColor="@color/text_primary"
        android:textColorHint="#9AA0A6"/>

    <!-- Confirm New Password -->
    <EditText
        android:id="@+id/edtConfirmNewPassword"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:hint="Xác nhận mật khẩu mới"
        android:inputType="textPassword"
        android:background="@drawable/bg_input_rounded"
        android:elevation="4dp"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:layout_marginBottom="24dp"
        android:textColor="@color/text_primary"
        android:textColorHint="#9AA0A6"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="2">

        <Button
            android:id="@+id/btnCancelChangePassword"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="Hủy"
            android:textSize="18sp"
            android:textAllCaps="false"
            android:textColor="@color/text_primary"
            android:background="@drawable/bg_button_rounded"
            app:backgroundTint="#E0E0E0"/>

        <Button
            android:id="@+id/btnConfirmChangePassword"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="Đổi mật khẩu"
            android:textSize="18sp"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:background="@drawable/bg_button_rounded"
            app:backgroundTint="@color/blue_tertiary"/>
    </LinearLayout>

</LinearLayout>
