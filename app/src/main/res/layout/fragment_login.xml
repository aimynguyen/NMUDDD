<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/blue_primary"
    android:clipChildren="false"
    android:clipToPadding="false">

    <!--top circle-->
    <View
        android:layout_width="587dp"
        android:layout_height="587dp"
        android:background="@drawable/bg_top_circle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:translationY="-353dp"
        android:translationX="-43sp"/>

    <!-- Logo + App name -->
    <View
        android:layout_width="600dp"
        android:layout_height="420dp"
        android:background="@drawable/appname_logo_01"
        android:layout_gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:translationX="-50dp"
        android:translationY="-110dp"
        />

    <!-- Username -->
    <EditText
        android:id="@+id/edtEmail"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginStart="25dp"
        android:layout_marginEnd="25dp"
        android:layout_marginTop="300dp"
        android:background="@drawable/bg_input_rounded"
        android:elevation="8dp"
        android:hint="Email"
        android:paddingStart="20dp"
        android:textColor="@color/text_primary"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Password -->
    <FrameLayout
        android:id="@+id/layoutPassword"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginTop="16dp"
        android:layout_marginStart="25dp"
        android:layout_marginEnd="25dp"
        android:elevation="8dp"
        android:background="@drawable/bg_input_rounded"
        app:layout_constraintTop_toBottomOf="@id/edtEmail"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <EditText
            android:id="@+id/edtPassword"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:color/transparent"
            android:hint="Password"
            android:inputType="textPassword"
            android:paddingStart="20dp"
            android:paddingEnd="48dp"
            android:textColor="@color/text_primary" />

        <ImageView
            android:id="@+id/imgTogglePassword"
            android:layout_width="48dp"
            android:layout_height="match_parent"
            android:layout_gravity="end|center_vertical"
            android:padding="14dp"
            android:src="@drawable/close_eye"
            android:scaleType="fitCenter" />
    </FrameLayout>

    <!-- Forgot -->
    <TextView
        android:id="@+id/txtForgot"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Forgot password?"
        android:textSize="12sp"
        android:layout_marginTop="6dp"
        android:layout_marginEnd="36dp"
        app:layout_constraintTop_toBottomOf="@id/layoutPassword"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!--bottom circle-->

    <View
        android:layout_width="610dp"
        android:layout_height="610dp"
        android:background="@drawable/bg_bottom_circle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:translationY="460dp"
        android:translationX="-160dp"/>

    <!-- Login -->
    <Button
        android:id="@+id/btnLogin"
        android:layout_width="180dp"
        android:layout_height="52dp"
        android:layout_marginTop="70dp"
        android:background="@drawable/bg_button_rounded"
        app:backgroundTint="@android:color/white"
        android:text="Login"
        android:textColor="@color/text_primary"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/txtForgot" />

    <!-- Register -->
    <Button
        android:id="@+id/btnRegister"
        android:layout_width="220dp"
        android:layout_height="52dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_button_rounded"
        app:backgroundTint="@android:color/white"
        android:text="Register"
        android:textColor="@color/text_primary"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnLogin" />

    




</androidx.constraintlayout.widget.ConstraintLayout>