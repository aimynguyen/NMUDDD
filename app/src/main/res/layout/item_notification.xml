<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="#FFFFFF">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="90dp"
        android:padding="16dp"
        >

        <!-- Thanh đo cho noti admin -->
        <View
            android:id="@+id/viewWarning"
            android:layout_width="4dp"
            android:layout_height="0dp"
            android:background="#D62D2D"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>

        <!-- Avatar / Icon -->
        <ImageView
            android:id="@+id/imgAvatar"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:scaleType="centerCrop"
            android:src="@drawable/avatar_circle"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>

        <!-- Noi dung -->
        <TextView
            android:id="@+id/txtContent"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:text="Minh Anh đã thả cảm xúc vào bài viết của bạn."
            android:textColor="#333333"
            android:textSize="16sp"
            android:lineSpacingExtra="2dp"
            app:layout_constraintStart_toEndOf="@id/imgAvatar"
            app:layout_constraintEnd_toStartOf="@id/viewUnread"
            app:layout_constraintTop_toTopOf="@id/imgAvatar"/>

        <!-- Thoi gian -->
        <TextView
            android:id="@+id/txtTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="5 phút trước"
            android:textColor="#777777"
            android:textSize="13sp"
            app:layout_constraintStart_toStartOf="@id/txtContent"
            app:layout_constraintTop_toBottomOf="@id/txtContent"/>

        <!-- Cham chua doc -->
        <View
            android:id="@+id/viewUnread"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/bg_unread_dot"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/txtContent"
            app:layout_constraintBottom_toBottomOf="@id/txtContent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>