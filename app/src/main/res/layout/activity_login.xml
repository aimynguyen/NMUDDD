<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/blue_primary"
    android:clipChildren="false"
    android:clipToPadding="false">

    <!--top circle-->
    <View
        android:layout_width="587dp"
        android:layout_height="587dp"
        android:background="@drawable/bg_top_circle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:translationY="-353dp"
        android:translationX="-43sp"/>

    <!-- Logo + App name -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/logoBlock"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="0dp">

        <!-- LOGO -->

        <!-- APP NAME -->
        <ImageView
            android:id="@+id/imgLogo"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:src="@drawable/auralog_logo"

            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/txtAppName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textSize="48sp"
            android:textColor="@color/white"
            android:fontFamily="@font/oleo_script_swash_caps_bold"

            app:layout_constraintStart_toStartOf="@id/imgLogo"
            app:layout_constraintTop_toTopOf="@id/imgLogo"

            android:translationX="-100dp"
            android:translationY="100dp"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!--Content-->


    
    <!--bottom circle-->

    <View
        android:layout_width="610dp"
        android:layout_height="610dp"
        android:background="@drawable/bg_bottom_circle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:translationY="460dp"
        android:translationX="-160dp"/>



</androidx.constraintlayout.widget.ConstraintLayout>