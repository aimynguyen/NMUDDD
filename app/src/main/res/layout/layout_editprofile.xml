<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_01"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingBottom="32dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="220dp">


            <ImageView
                android:id="@+id/imgAvatar"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_gravity="center"
                android:src="@drawable/human_human"
                android:background="@drawable/bg_circle_white"
                android:elevation="8dp"
                android:padding="15dp"
                />

            <ImageView
                android:id="@+id/btnCamera"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_gravity="center"
                android:layout_marginStart="40dp"
                android:layout_marginTop="40dp"
                android:background="@drawable/bg_circle_white"
                android:elevation="10dp"
                android:padding="5dp"
                android:src="@drawable/camera"
                app:tint="@null"/>

        </FrameLayout>

    <!-- CARD -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="28dp"
        android:layout_marginTop="-35dp"
        android:background="@drawable/bg_gradient_reverse"
        android:elevation="5dp"
        android:orientation="vertical"
        android:padding="28dp">

        <!-- Name -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your new name"
            android:textColor="@color/text_primary"
            android:textSize="18sp" />

        <EditText
            android:id="@+id/edtName"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_rounded"
            android:hint="Enter your new name"
            android:paddingHorizontal="16dp"
            android:textColor="@color/text_primary"
            android:textColorHint="#9AA0A6" />

        <!-- Email -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Email"
            android:textColor="@color/text_primary"
            android:textSize="18sp" />

        <EditText
            android:id="@+id/edtEmail"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_rounded"
            android:enabled="false"
            android:paddingHorizontal="16dp"
            android:textColor="@color/text_primary"
            android:textColorHint="#9AA0A6" />

        <!-- Avatarurl -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Avatar URL"
            android:textColor="@color/text_primary"
            android:textSize="18sp" />

        <EditText
            android:id="@+id/edtAvatarUrl"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_rounded"
            android:hint="Enter your avatar URL"
            android:paddingHorizontal="16dp"
            android:textColor="@color/text_primary"
            android:textColorHint="#9AA0A6" />


        <!-- Confirm Your Password -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Confirm your password"
            android:textColor="@color/text_primary"
            android:textSize="18sp" />

        <EditText
            android:id="@+id/edtConfirmPassword"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_rounded"
            android:hint="Confirm your password"
            android:inputType="textPassword"
            android:paddingHorizontal="16dp"
            android:textColor="@color/text_primary"
            android:textColorHint="#9AA0A6" />

        <!-- Note -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:lineSpacingExtra="3dp"
            android:text="You can only change your name once every 14 days."
            android:textColor="@color/gray_medium"
            android:textSize="13sp" />

        <!-- Button -->
        <Button
            android:id="@+id/btnFinish"
            android:layout_width="140dp"
            android:layout_height="52dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="28dp"
            android:background="@drawable/bg_button_rounded"
            android:text="Finish"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold"
            />

    </LinearLayout>

    </LinearLayout>

</ScrollView>